# ========== API KEYS ==========
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ========== AI MODE ==========
# "free" = Ollama local (no cost), "premium" = Anthropic Claude API (best quality)
AI_MODE=premium

# ========== LINKEDIN CREDENTIALS ==========
LINKEDIN_EMAIL=your_linkedin_email@example.com
LINKEDIN_PASSWORD=your_linkedin_password

# ========== DICE CREDENTIALS ==========
DICE_EMAIL=your_dice_email@example.com
DICE_PASSWORD=your_dice_password

# ========== PERSONAL INFO ==========
PHONE=your_phone_number
CITY_STATE=Your City, State, United States
CITY=Your City
STATE=TX
ZIP=00000

# ========== SETTINGS ==========
MAX_PER_PLATFORM=20
